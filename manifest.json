{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "X Follow Grow - Safe & Smart Auto Follow Tool for X/Twitter",
  "version": "2.0.0",
  "description": "Smart auto follow extension for X/Twitter with queue mode, smart filters, safe automation, and human-like behaviour.",
  "author": "Shahriar Ahmed",
  "minimum_chrome_version": "110",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms",
    "downloads",
    "notifications"
  ],

  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://mobile.twitter.com/*"
  ],

  "background": {
    "service_worker": "core/serviceWorker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": ["features/follow/contentScript.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "ui/pages/popup.html",
    "default_title": "X Follow Grow",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "ui/pages/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["ui/styles/*.css", "icons/*.png"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ]
}
